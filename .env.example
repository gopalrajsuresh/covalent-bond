# Covalent Bond configuration.
# Copy this file to .env (same folder); the MCP server reads it at startup.
# A real environment variable with the same name always takes precedence.

# The relay both machines meet through. Exactly one COVALENT_RELAY_URL line
# should be active; both machines must use the same relay.

# Option 1: the public relay (default, works out of the box).
COVALENT_RELAY_URL=https://covalent-bond-relay.gopalrajsuresh.workers.dev

# Option 2: your own deployed Cloudflare Worker. Uncomment and replace
# <your-subdomain> with the URL printed by `wrangler deploy`.
# COVALENT_RELAY_URL=https://covalent-bond-relay.<your-subdomain>.workers.dev

# Option 3: the local mock relay for testing on one machine.
# Start it first with: npm run relay:dev
# COVALENT_RELAY_URL=http://localhost:8787

# Optional: max file size in KB (default 256, hard ceiling 384).
# COVALENT_MAX_FILE_KB=256

# Optional: set to "off" to disable desktop notifications.
# COVALENT_NOTIFICATIONS=on

# Optional: set to "off" to disable desktop notifications.
# COVALENT_NOTIFICATIONS=on
